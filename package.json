    "@types/node": "^24",
    "@types/nodemailer": "^6.4.23",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/winston-mail": "^1.5.5",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^4.27.0",
    "@typescript-eslint/parser": "^4.27.0",
    "babel-plugin-inline-react-svg": "^2.0.2",
    "babel-plugin-istanbul": "^6.0.0",
    "check-code-coverage": "^1.10.5",
    "concurrently": "^5.3.0",
    "cypress": "^15",
    "dotenv-cli": "^4.0.0",
    "eslint": "7.32.0",
    "eslint-config-next": "11.1.0",
    "eslint-config-prettier": "^8.3.0",
    "js-yaml": "^3.14.1",
    "nyc": "^15.1.0",
    "prettier": "^2.1.2",
    "prisma": "^6",
    "prisma-generator-pothos-codegen": "^0.7.2",
    "simplytyped": "^3.3.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^9.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "yargs": "16.0.0"
  },
  "repository": {
    "type": "git",
