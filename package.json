{
  "name": "voty",
  "engines": {
    "node": ">=24"
  },
  "version": "1.3.0-development",
  "private": true,
  "scripts": {
    "start": "next start",
    "dev": "yarn gen:glossary && next dev",
    "build": "yarn gen:glossary && next build",
    "gen:glossary": "tsx scripts/gen-glossary.ts",
    "start:test": "next &",
    "cy": "dotenv -- cypress open",
    "test": "dotenv -- cypress run --record false",
    "deploy": "./ansible/scripts/deploy.py",
    "deploy:dev": "ansible-playbook -i ansible/dev ansible/site.yml --tags app",
    "deploy:prod": "ansible-playbook -i ansible/prod ansible/site.yml --tags app",
    "deploy:backup": "ansible-playbook -i ansible/backup ansible/site.yml --tags app",
    "deploy:tools": "ansible-playbook -i ansible/prod ansible/site.yml --tags civictools",
    "site:dev": "ansible-playbook -i ansible/dev ansible/site.yml",
    "site:prod": "ansible-playbook -i ansible/prod ansible/site.yml",
    "site:backup": "ansible-playbook -i ansible/backup ansible/site.yml",
    "migrate:dev": "ansible-playbook -i ansible/dev ansible/migrate.yml",
    "migrate:prod": "ansible-playbook -i ansible/prod ansible/migrate.yml",
    "migrate:backup": "ansible-playbook -i ansible/backup ansible/migrate.yml",
    "init:db": "npx prisma migrate dev --preview-feature",
    "reset:db": "tsx ansible/scripts/prisma-loader-cli.ts cypress/fixtures/testdb.yml",
    "load:db": "tsx ansible/scripts/prisma-loader-cli.ts",
    "ci:test": "yarn ci:release && yarn init:db && yarn start:test && dotenv -- sh -c 'cypress run ${CYPRESS_RECORD_KEY:+--record}'",
    "ci:release": "yarn install --frozen-lockfile && npx prisma generate && yarn run build",
    "graphql": "graphql-codegen --config codegen.yml",
    "check:ts": "tsc --noEmit",
    "schema:print": "tsx graphql/printSchema.ts",
    "lint": "next lint"
  },
  "dependencies": {
    "@apollo/client": "^3.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/loader": "^3",
    "@mdx-js/react": "^3",
    "@next/mdx": "^16",
    "@pothos/core": "^4",
    "@pothos/plugin-prisma": "^4",
    "@pothos/plugin-prisma-utils": "^1",
    "@pothos/plugin-scope-auth": "^4.1.6",
    "@prisma/client": "^6",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "dayjs": "^1.11.20",
    "formidable": "^3.5.4",
    "graphql": "^16",
    "graphql-scalars": "^1.25.0",
    "graphql-yoga": "^5",
    "imap-simple": "^5.1.0",
    "jotai": "^2.19.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "mjml": "^5.1.0",
    "mustache": "^4.2.0",
    "next": "^16",
    "nodemailer": "^9.0.1",
    "prismjs": "^1.30.0",
    "qrcode.react": "^4",
    "react": "^19",
    "react-dom": "^19",
    "react-draggable-list": "^4.2.1",
    "react-hook-form": "^7.74.0",
    "react-markdown": "^10",
    "react-minimal-pie-chart": "^9.1.2",
    "react-new-window": "^1",
    "react-player": "^3",
    "remark-gfm": "^4.0.1",
    "remark-images": "^4.1.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "winston": "^3.19.0",
    "winston-mail": "^2.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@divyenduz/ts-graphql-plugin": "^0.1.0",
    "@graphql-codegen/cli": "^5",
    "@graphql-codegen/fragment-matcher": "^5",
    "@graphql-codegen/introspection": "1.18.1",
    "@graphql-codegen/typescript": "^4",
    "@graphql-codegen/typescript-graphql-files-modules": "^3",
    "@graphql-codegen/typescript-operations": "^4",
    "@graphql-codegen/typescript-react-apollo": "^4",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/cypress": "10.1.3",
    "@types/formidable": "^3.5.1",
    "@types/imap-simple": "^4.2.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.0",
    "@types/mdx": "^2.0.13",
    "@types/mjml": "^5.0.0",
    "@types/mustache": "^4.2.6",
    "@types/node": "^25",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/winston-mail": "^1.5.5",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^4.27.0",
    "@typescript-eslint/parser": "^4.27.0",
    "babel-plugin-inline-react-svg": "^2.0.2",
    "cypress": "^15.14.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "7.32.0",
    "eslint-config-next": "11.1.0",
    "eslint-config-prettier": "^10.1.8",
    "js-yaml": "^4.1.1",
    "prettier": "^2.1.2",
    "prisma": "^6",
    "prisma-generator-pothos-codegen": "^0.7.2",
    "simplytyped": "^3.3.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "yargs": "^18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/teachen-ch/voty.git"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "resolutions": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@babel/runtime": "^7.29.2",
    "braces": "^3.0.3",
    "cross-spawn": "^7.0.5",
    "lodash": "^4.18.0",
    "node-fetch": "2.7.0",
    "postcss": "^8.5.8",
    "js-yaml": "^4.1.0",
    "semver": "^7.7.3",
    "eslint/**/minimatch": "3.1.5",
    "eslint-config-next/**/minimatch": "3.1.5",
    "@divyenduz/ts-graphql-plugin/**/minimatch": "3.1.5"
  }
}
